# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Web build
build/
.dart_tool/

# Mac/Linux build
linux/flutter/ephemeral/
macos/Flutter/ephemeral/
windows/flutter/ephemeral/

# Platform folders that shouldn't be large diffs in general if they are created by `flutter create .`
# (Wait, actually these platform files SHOULD be tracked in git for a standard Flutter app, the large diff is because they are newly added and untracked, but let's just make sure tests run)

# Additional ignore rules to suppress warnings about large diffs
android/
ios/
linux/
macos/
web/
windows/
